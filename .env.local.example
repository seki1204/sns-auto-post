# === BigQuery 設定 (GA4 エクスポート) ===
# GCPプロジェクトID
BIGQUERY_PROJECT_ID=databeatwaca210204

# GA4 BigQueryエクスポートのデータセット名
BIGQUERY_DATASET=analytics_334575663

# サービスアカウントキーファイルのパス
# GCPコンソール > IAM > サービスアカウント > キー > JSON で作成
# BigQuery データ閲覧者 (roles/bigquery.dataViewer) 権限が必要
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# === Claude API 設定 ===
# Anthropic APIキー (https://console.anthropic.com/ で取得)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
